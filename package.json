{
  "name": "kubb-plugins",
  "version": "0.0.0",
  "private": true,
  "description": "Community-driven monorepo of Kubb plugins",
  "repository": {
    "type": "git",
    "url": "https://github.com/kubb-labs/plugins.git"
  },
  "license": "MIT",
  "author": "stijnvanhulle",
  "type": "module",
  "workspaces": {
    "packages": [
      "packages/*",
      "internals/*",
      "examples/*"
    ]
  },
  "scripts": {
    "build": "turbo run build --filter=./packages/*",
    "build:examples": "turbo run build --filter=./examples/*",
    "changeset": "changeset",
    "clean": "turbo run clean",
    "format": "biome format --write ./ && biome check --fix --unsafe",
    "generate": "KUBB_DISABLE_TELEMETRY=1 turbo run generate --filter=./examples/* --continue --concurrency=5",
    "postgenerate": "pnpm run lint:fix && pnpm run format",
    "lint": "biome lint ./packages",
    "lint:fix": "biome lint --write --unsafe ./packages && manypkg fix",
    "start": "turbo run start --filter=./packages/*",
    "test": "vitest run --config ./configs/vitest.config.ts --coverage",
    "test:watch": "vitest --config ./configs/vitest.config.ts",
    "typecheck": "turbo run typecheck --continue --filter='./packages/*'",
    "typecheck:examples": "turbo run typecheck --continue --filter='./examples/*'",
    "upgrade": "npx taze -r -w --exclude pnpm",
    "version": "changeset version",
    "version:canary": "changeset version --snapshot canary"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.30.0",
    "@manypkg/cli": "^0.25.1",
    "@size-limit/file": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "bun-types": "^1.3.12",
    "prettier": "^3.8.3",
    "size-limit": "catalog:",
    "taze": "^19.11.0",
    "ts-node": "^10.9.2",
    "tsdown": "catalog:",
    "turbo": "^2.9.6",
    "typescript": "catalog:",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@10.30.1",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "namespace": "@kubb"
}
