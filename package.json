{
  "name": "@kubb/plugins",
  "version": "0.0.0",
  "private": true,
  "description": "Kubb's monorepo",
  "license": "MIT",
  "author": "stijnvanhulle",
  "repository": {
    "type": "git",
    "url": "https://github.com/kubb-labs/plugins.git"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "internals/*",
      "examples/*",
      "tests/**"
    ]
  },
  "type": "module",
  "scripts": {
    "build": "turbo run build --filter=./packages/*",
    "build:extension-yaml": "tsx scripts/build-extension-yaml.ts",
    "build:examples": "turbo run build --filter=./examples/*",
    "test:bench": "vitest bench --config ./configs/vitest.bench.config.ts",
    "changeset": "changeset",
    "clean": "turbo run clean",
    "format": "oxfmt -c oxfmt.config.ts packages internals configs examples",
    "generate": "KUBB_DISABLE_TELEMETRY=1 turbo run generate --filter=./examples/* --continue --concurrency=5",
    "postgenerate": "pnpm run lint:fix && pnpm run format",
    "graph": "npx nx graph ",
    "lint": "oxlint -c oxlint.config.ts ./packages ./examples",
    "lint:fix": "oxlint -c oxlint.config.ts --fix ./packages ./examples",
    "lint:spell": "cspell \"**/*.{ts,md}\" --config ./cspell.json --no-progress",
    "release": "changeset publish",
    "release:canary": "changeset publish --no-git-tag",
    "start": "turbo run start --filter=./packages/*",
    "test": "vitest run --config ./configs/vitest.config.ts --coverage",
    "test:watch": "vitest --config ./configs/vitest.config.ts",
    "typecheck": "turbo run typecheck --continue --filter='./packages/*' --filter='./tests/**'",
    "typecheck:examples": "turbo run typecheck --continue --filter='./examples/*'",
    "upgrade": "npx taze -r -w --exclude pnpm",
    "version": "changeset version",
    "version:canary": "changeset version --snapshot canary"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@kubb/adapter-oas": "catalog:",
    "@kubb/core": "catalog:",
    "@kubb/middleware-barrel": "catalog:",
    "@kubb/parser-ts": "catalog:",
    "@kubb/plugin-cypress": "workspace:*",
    "@kubb/plugin-ts": "workspace:*",
    "@kubb/plugin-zod": "workspace:*",
    "@size-limit/file": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "bun-types": "^1.3.13",
    "cspell": "^10.0.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "prettier": "^3.8.3",
    "size-limit": "catalog:",
    "taze": "^19.11.0",
    "tsdown": "catalog:",
    "tsx": "^4.21.0",
    "turbo": "^2.9.9",
    "typescript": "catalog:",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "catalog:",
    "yaml": "^2.8.4"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "namespace": "@kubb"
}
