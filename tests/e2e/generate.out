ner":"/**\n* Generated by Kubb (https://kubb.dev/).\n* Do not edit manually.\n*/\n","sources":[{"name":"bookingPaymentCurrencyEnum","isTypeOnly":false,"isExportable":true,"isIndexable":true,"nodes":[{"value":"export const bookingPaymentCurrencyEnum = {\n    bam: \"bam\",\n    bgn: \"bgn\",\n    chf: \"chf\",\n    eur: \"eur\",\n    gbp: \"gbp\",\n    nok: \"nok\",\n    sek: \"sek\",\n    try: \"try\"\n} as const;\n","kind":"Text"}],"kind":"Source"},{"name":"BookingPaymentCurrencyEnumKey","isTypeOnly":true,"isExportable":true,"isIndexable":true,"nodes":[{"value":"export type BookingPaymentCurrencyEnumKey = (typeof bookingPaymentCurrencyEnum)[keyof typeof bookingPaymentCurrencyEnum];\n","kind":"Text"}],"kind":"Source"},{"name":"objectEnum","isTypeOnly":false,"isExportable":true,"isIndexable":true,"nodes":[{"value":"export const objectEnum = {\n    bank_account: \"bank_account\"\n} as const;\n","kind":"Text"}],"kind":"Source"},{"name":"ObjectEnumKey","isTypeOnly":true,"isExportable":true,"isIndexable":true,"nodes":[{"value":"export type ObjectEnumKey = (typeof objectEnum)[keyof typeof objectEnum];\n","kind":"Text"}],"kind":"Source"},{"name":"accountTypeEnum","isTypeOnly":false,"isExportable":true,"isIndexable":true,"nodes":[{"value":"export const accountTypeEnum = {\n    individual: \"individual\",\n    company: \"company\"\n} as const;\n","kind":"Text"}],"kind":"Source"},{"name":"AccountTypeEnumKey","isTypeOnly":true,"isExportable":true,"isIndexable":true,"nodes":[{"value":"export type AccountTypeEnumKey = (typeof accountTypeEnum)[keyof typeof accountTypeEnum];\n","kind":"Text"}],"kind":"Source"},{"name":"bookingPaymentStatusEnum","isTypeOnly":false,"isExportable":true,"isIndexable":true,"nodes":[{"value":"export const bookingPaymentStatusEnum = {\n    pending: \"pending\",\n    succeeded: \"succeeded\",\n    failed: \"failed\"\n} as const;\n","kind":"Text"}],"kind":"Source"},{"name":"BookingPaymentStatusEnumKey","isTypeOnly":true,"isExportable":true,"isIndexable":true,"nodes":[{"value":"export type BookingPaymentStatusEnumKey = (typeof bookingPaymentStatusEnum)[keyof typeof bookingPaymentStatusEnum];\n","kind":"Text"}],"kind":"Source"},{"name":"BookingPayment","isTypeOnly":true,"isExportable":true,"isIndexable":true,"nodes":[{"value":"/**\n * @description A payment for a booking.\n * @type object\n*/\nexport type BookingPayment = {\n    /**\n     * @description Unique identifier for the payment. This will be a unique identifier for the payment, and is used to reference the payment in other objects.\n     * @type string | undefined\n    */\n    readonly id?: string;\n    /**\n     * @description Amount intended to be collected by this payment. A positive decimal figure describing the amount to be collected.\n     * @type number | undefined\n    */\n    amount?: number;\n    /**\n     * @description Three-letter [ISO currency code](https://www.iso.org/iso-4217-currency-codes.html), in lowercase.\n     * @type string | undefined\n    */\n    currency?: BookingPaymentCurrencyEnumKey;\n    /**\n     * @description The payment source to take the payment from. This can be a card or a bank account. Some of these properties will be hidden on read to protect PII leaking.\n    */\n    source?: ({\n        /**\n         * @type string | undefined\n        */\n        object?: ObjectEnumKey;\n        /**\n         * @description Cardholder\\'s full name as it appears on the card.\n         * @type string\n        */\n        name: string;\n        /**\n         * @description The card number, as a string without any separators. On read all but the last four digits will be masked for security.\n         * @type string\n        */\n        number: string;\n        /**\n         * @description Card security code, 3 or 4 digits usually found on the back of the card.\n         * @minLength 3\n         * @maxLength 4\n         * @example 123\n         * @type string\n        */\n        cvc: string;\n        /**\n         * @description Two-digit number representing the card\\'s expiration month.\n         * @type integer\n        */\n        exp_month: number;\n        /**\n         * @description Four-digit number representing the card\\'s expiration year.\n         * @type integer\n        */\n        exp_year: number;\n        /**\n         * @type string | undefined\n        */\n        address_line1?: string;\n        /**\n         * @type string | undefined\n        */\n        address_line2?: string;\n        /**\n         * @type string | undefined\n        */\n        address_city?: string;\n        /**\n         * @type string\n        */\n        address_country: string;\n        /**\n         * @type string | undefined\n        */\n        address_post_code?: string;\n    } | {\n        /**\n         * @type string | undefined\n        */\n        object?: ObjectEnumKey;\n        /**\n         * @type string\n        */\n        name: string;\n        /**\n         * @description The account number for the bank account, in string form. Must be a current account.\n         * @type string\n        */\n        number: string;\n        /**\n         * @description The sort code for the bank account, in string form. Must be a six-digit number.\n         * @type string | undefined\n        */\n        sort_code?: string;\n        /**\n         * @description The type of entity that holds the account. This can be either `individual` or `company`.\n         * @type string\n        */\n        account_type: AccountTypeEnumKey;\n        /**\n         * @description The name of the bank associated with the routing number.\n         * @type string\n        */\n        bank_name: string;\n        /**\n         * @description Two-letter country code (ISO 3166-1 alpha-2).\n         * @type string\n        */\n        country: string;\n    });\n    /**\n     * @description The status of the payment, one of `pending`, `succeeded`, or `failed`.\n     * @type string | undefined\n    */\n    readonly status?: BookingPaymentStatusEnumKey;\n};\n","kind":"Text"}],"kind":"Source"}],"exports":[],"imports":[],"id":"73ea5def995dc33db7fea2f4db222f63381b8961c9fb69f7055edcd3509992e7","name":"BookingPayment","extname":".ts"},{"kind":"File","baseName":"bookingPaymentSchema.ts","path":"/home/runner/work/plugins/plugins/tests/e2e/gen/zod/bookingPaymentSchema.ts","meta":{"pluginName":"plugin-zod"},"banner":"/**\n* Generated by Kubb (https://kubb.dev/).\n* Do not edit manually.\n*/\n","sources":[{"name":"bookingPaymentSchema","isTypeOnly":false,"isExportable":true,"isIndexable":true,"nodes":[{"name":"bookingPaymentSchema","export":true,"nodes":[{"value":"z.object({\n    \"id\": z.uuid().optional().describe(\"Unique identifier for the payment. This will be a unique identifier for the payment, and is used to reference the payment in other objects.\"),\n    \"amount\": z.number().gt(0).optional().describe(\"Amount intended to be collected by this payment. A positive decimal figure describing the amount to be collected.\"),\n    \"currency\": z.enum([\"bam\", \"bgn\", \"chf\", \"eur\", \"gbp\", \"nok\", \"sek\", \"try\"]).optional().describe(\"Three-letter [ISO currency code](https://www.iso.org/iso-4217-currency-codes.html), in lowercase.\"),\n    \"source\": z.union([z.object({\n    \"object\": z.enum([\"card\"]).optional(),\n    \"name\": z.string().describe(\"Cardholder's full name as it appears on the card.\"),\n    \"number\": z.string().describe(\"The card number, as a string without any separators. On read all but the last four digits will be masked for security.\"),\n    \"cvc\": z.string().min(3).max(4).describe(\"Card security code, 3 or 4 digits usually found on the back of the card.\"),\n    \"exp_month\": z.int().describe(\"Two-digit number representing the card's expiration month.\"),\n    \"exp_year\": z.int().describe(\"Four-digit number representing the card's expiration year.\"),\n    \"address_line1\": z.string().optional(),\n    \"address_line2\": z.string().optional(),\n    \"address_city\": z.string().optional(),\n    \"address_country\": z.string(),\n    \"address_post_code\": z.string().optional()\n    }), z.object({\n    \"object\": z.enum([\"bank_account\"]).optional(),\n    \"name\": z.string(),\n    \"number\": z.string().describe(\"The account number for the bank account, in string form. Must be a current account.\"),\n    \"sort_code\": z.string().optional().describe(\"The sort code for the bank account, in string form. Must be a six-digit number.\"),\n    \"account_type\": z.enum([\"individual\", \"company\"]).describe(\"The type of entity that holds the account. This can be either `individual` or `company`.\"),\n    \"bank_name\": z.string().describe(\"The name of the bank associated with the routing number.\"),\n    \"country\": z.string().describe(\"Two-letter country code (ISO 3166-1 alpha-2).\")\n    })]).optional().describe(\"The payment source to take the payment from. This can be a card or a bank account. Some of these properties will be hidden on read to protect PII leaking.\"),\n    \"status\": z.enum([\"pending\", \"succeeded\", \"failed\"]).optional().describe(\"The status of the payment, one of `pending`, `succeeded`, or `failed`.\")\n    }).describe(\"A payment for a booking.\")","kind":"Text"}],"kind":"Const"}],"kind":"Source"},{"name":"BookingPaymentSchema","isTypeOnly":true,"isExportable":true,"isIndexable":true,"nodes":[{"name":"BookingPaymentSchema","export":true,"nodes":[{"value":"z.infer<typeof bookingPaymentSchema>","kind":"Text"}],"kind":"Type"}],"kind":"Source"}],"exports":[],"imports":[{"name":"z","path":"zod","isTypeOnly":false,"isNameSpace":true,"kind":"Import"}],"id":"287f32ee6ddff4aa7c5431c30ba3477508de274703e05a5d356f56cb8af91dba","name":"bookingPaymentSchema","extname":".ts"},{"kind":"File","baseName":"LinksPagination.ts","path":"/home/runner/work/plugins/plugins/tests/e2e/gen/models/ts/LinksPagination.ts","meta":{"pluginName":"plugin-ts"},"banner":"/**\n* Generated by Kubb (https://kubb.dev/)