":"enum","enumValues":["card"],"name":"ObjectEnum","kind":"Schema","optional":true},"required":false,"kind":"Property"},{"name":"name","schema":{"primitive":"string","type":"string","name":null,"description":"Cardholder's full name as it appears on the card.","kind":"Schema"},"required":true,"kind":"Property"},{"name":"number","schema":{"primitive":"string","type":"string","name":null,"description":"The card number, as a string without any separators. On read all but the last four digits will be masked for security.","kind":"Schema"},"required":true,"kind":"Property"},{"name":"cvc","schema":{"primitive":"string","type":"string","min":3,"max":4,"name":null,"description":"Card security code, 3 or 4 digits usually found on the back of the card.","writeOnly":true,"example":"123","kind":"Schema"},"required":true,"kind":"Property"},{"name":"exp_month","schema":{"primitive":"integer","type":"integer","name":null,"description":"Two-digit number representing the card's expiration month.","kind":"Schema"},"required":true,"kind":"Property"},{"name":"exp_year","schema":{"primitive":"integer","type":"integer","name":null,"description":"Four-digit number representing the card's expiration year.","kind":"Schema"},"required":true,"kind":"Property"},{"name":"address_line1","schema":{"primitive":"string","type":"string","name":null,"writeOnly":true,"kind":"Schema","optional":true},"required":false,"kind":"Property"},{"name":"address_line2","schema":{"primitive":"string","type":"string","name":null,"writeOnly":true,"kind":"Schema","optional":true},"required":false,"kind":"Property"},{"name":"address_city","schema":{"primitive":"string","type":"string","name":null,"kind":"Schema","optional":true},"required":false,"kind":"Property"},{"name":"address_country","schema":{"primitive":"string","type":"string","name":null,"kind":"Schema"},"required":true,"kind":"Property"},{"name":"address_post_code","schema":{"primitive":"string","type":"string","name":null,"kind":"Schema","optional":true},"