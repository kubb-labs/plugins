 }\n  }\n\n  if (data) {\n    Object.entries(data).forEach(([key, value]) => {\n      if (value === undefined || value === null) return\n\n      if (Array.isArray(value)) {\n        for (const valueItem of value) {\n          if (valueItem === undefined || valueItem === null) continue\n          appendData(key, valueItem)\n        }\n      } else {\n        appendData(key, value)\n      }\n    })\n  }\n\n  return formData\n}\n","kind":"Text"}],"isExportable":false,"isIndexable":false,"kind":"Source"}],"baseName":"config.ts","path":"/home/runner/work/plugins/plugins/tests/e2e/src/gen/.kubb/config.ts","id":"c17c4d1e08ce4f701dc646099d9527e17856ffee605d4671b22174bd00daad02","name":"config","extname":".ts","meta":{}},{"kind":"File","baseName":"Tag.ts","path":"/home/runner/work/plugins/plugins/tests/e2e/src/gen/models/ts/Tag.ts","meta":{"pluginName":"plugin-ts"},"banner":"/**\n* Generated by Kubb (https://kubb.dev/).\n* Do not edit manually.\n*/\n","sources":[{"name":"Tag","isTypeOnly":true,"isExportable":true,"isIndexable":true,"nodes":[{"value":"/**\n * @type object\n*/\nexport type Tag = {\n    /**\n     * @type integer | undefined\n    */\n    id?: number;\n    /**\n     * @type string | undefined\n    */\n    name?: string;\n};\n","kind":"Text"}],"kind":"Source"}],"exports":[],"imports":[],"id":"b50126d35b2beefee132718045dde9f7c4e0b8a1355b287ba876ee1e1bf24a12","name":"Tag","extname":".ts"},{"kind":"File","baseName":"Pet.ts","path":"/home/runner/work/plugins/plugins/tests/e2e/src/gen/models/ts/Pet.ts","meta":{"pluginName":"plugin-ts"},"banner":"/**\n* Generated by Kubb (https://kubb.dev/).\n* Do not edit manually.\n*/\n","sources":[{"name":"petStatusEnum","isTypeOnly":false,"isExportable":true,"isIndexable":true,"nodes":[{"value":"export const petStatusEnum = {\n    available: \"available\",\n    pending: \"pending\",\n    sold: \"sold\"\n} as const;\n","kind":"Text"}],"kind":"Source"},{"name":"PetStatusEnumKey","isTypeOnly":true,"isExportable":true,"isIndexable":true