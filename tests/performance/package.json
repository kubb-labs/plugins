{
  "name": "performance",
  "version": "0.0.1-beta.7",
  "private": true,
  "description": "Performance benchmarks for Kubb plugin generation",
  "repository": {
    "type": "git",
    "url": "https://github.com/kubb-labs/plugins.git",
    "directory": "tests/performance"
  },
  "license": "MIT",
  "author": "stijnvanhulle",
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "typecheck": "tsc -p ./tsconfig.json --noEmit --emitDeclarationOnly false",
    "perf:stripe": "node --max-old-space-size=2048 --import tsx ./stripe.ts",
    "perf:stripe:4g": "node --max-old-space-size=4096 --import tsx ./stripe.ts",
    "perf:stripe:6g": "node --max-old-space-size=6144 --import tsx ./stripe.ts"
  },
  "dependencies": {
    "@internals/utils": "workspace:*",
    "@kubb/adapter-oas": "catalog:",
    "@kubb/core": "catalog:",
    "@kubb/plugin-faker": "workspace:*",
    "@kubb/plugin-ts": "workspace:*",
    "@kubb/plugin-zod": "workspace:*",
    "kubb": "catalog:",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@10.30.1",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10.0.0"
  }
}
