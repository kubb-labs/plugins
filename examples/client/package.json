{
  "name": "client-pet-store",
  "version": "0.0.2-alpha.0",
  "private": true,
  "description": "Client PetStore example",
  "repository": {
    "type": "git",
    "url": "https://github.com/kubb-labs/kubb.git",
    "directory": "examples/client"
  },
  "license": "MIT",
  "author": "stijnvanhulle",
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "clean": "npx rimraf ./dist",
    "generate": "KUBB_DISABLE_TELEMETRY=1 kubb generate --config kubb.config.ts && node ./build.ts",
    "generate:build": "node ./build.ts",
    "test": "vitest",
    "typecheck": "tsc -p ./tsconfig.json --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@kubb/adapter-oas": "catalog:",
    "@kubb/core": "catalog:",
    "@kubb/parser-ts": "catalog:",
    "@kubb/plugin-client": "workspace:*",
    "@kubb/plugin-ts": "workspace:*",
    "@kubb/renderer-jsx": "catalog:",
    "axios": "^1.15.0",
    "kubb": "catalog:"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "react": "^19.2.5",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.30.1",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10.0.0"
  }
}
