{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ES2020",
    "moduleResolution": "Bundler",
    "sourceMap": true,
    "strictNullChecks": true,
    "outDir": "es",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowJs": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "jsx": "react-jsx"
  },
  "include": ["./src/**/*", "./kubb.config.ts"],
  "exclude": ["**/node_modules", "**/types/**", "**/mocks/**"]
}
