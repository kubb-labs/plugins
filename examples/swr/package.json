    "typescript": "catalog:"
  },
  "devDependencies": {
    "@types/react": "catalog:"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.30.1"
