{
  "name": "advanced-pet-store",
  "version": "0.0.0",
  "private": true,
  "description": "Advanced PetStore example",
  "license": "MIT",
  "author": "stijnvanhulle",
  "repository": {
    "type": "git",
    "url": "https://github.com/kubb-labs/plugins.git",
    "directory": "examples/advanced"
  },
  "sideEffects": false,
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('./dist', {recursive:true,force:true})\"",
    "generate": "KUBB_DISABLE_TELEMETRY=1 kubb generate",
    "validate": "kubb validate --input petStore.yaml",
    "mcp": "kubb mcp",
    "generate:watch": "KUBB_DISABLE_TELEMETRY=1 kubb generate --watch",
    "generate:debug": "NODE_OPTIONS='--inspect-brk' KUBB_DISABLE_TELEMETRY=1 kubb generate",
    "init": "kubb init -y",
    "generate:ts": "KUBB_DISABLE_TELEMETRY=1 kubb generate --config configs/kubb.config.ts",
    "test": "vitest",
    "typecheck": "tsc -p ./tsconfig.json --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@faker-js/faker": "^10.5.0",
    "@kubb/plugin-axios": "workspace:*",
    "@kubb/plugin-cypress": "workspace:*",
    "@kubb/plugin-faker": "workspace:*",
    "@kubb/plugin-mcp": "workspace:*",
    "@kubb/plugin-msw": "workspace:*",
    "@kubb/plugin-react-query": "workspace:*",
    "@kubb/plugin-redoc": "workspace:*",
    "@kubb/plugin-zod": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tanstack/query-core": "^5.101.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/vue-query": "^5.101.2",
    "@types/react": "catalog:",
    "axios": "^1.18.1",
    "cypress": "^15.18.0",
    "msw": "^2.14.6",
    "react": "^19.2.7",
    "solid-js": "^1.9.14",
    "svelte": "^5.56.4",
    "swr": "^2.4.2",
    "vue": "^3.5.39",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@kubb/adapter-oas": "catalog:",
    "@kubb/plugin-ts": "workspace:*",
    "kubb": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.30.1"
}
