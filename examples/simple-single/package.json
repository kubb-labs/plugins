{
  "name": "simple-single-pet-store",
  "version": "0.0.0",
  "private": true,
  "description": "Simple single PetStore example",
  "license": "MIT",
  "author": "stijnvanhulle",
  "repository": {
    "type": "git",
    "url": "https://github.com/kubb-labs/plugins.git",
    "directory": "examples/single-single"
  },
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "generate": "KUBB_DISABLE_TELEMETRY=1 kubb generate --config kubb.config.js -l info",
    "generate:bun": "bun node_modules/@kubb/cli/bin/kubb.js generate --config kubb.config.js",
    "generate:js": "KUBB_DISABLE_TELEMETRY=1 kubb generate --config .kubbrc",
    "generate:json": "KUBB_DISABLE_TELEMETRY=1 kubb generate --config kubb.json",
    "test": "vitest",
    "typecheck": "tsc -p ./tsconfig.json --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@kubb/adapter-oas": "catalog:",
    "@kubb/plugin-client": "workspace:*",
    "@kubb/plugin-react-query": "workspace:*",
    "@kubb/plugin-redoc": "workspace:*",
    "@kubb/plugin-ts": "workspace:*",
    "@kubb/plugin-zod": "workspace:*",
    "@tanstack/react-query": "^5.100.6",
    "axios": "^1.15.2",
    "kubb": "catalog:",
    "react": "^19.2.5",
    "typescript": "catalog:",
    "zod": "^4.4.1"
  }
}
