{
  "extends": "./bundler.json",
  "compilerOptions": {
    "rootDir": ".",
    "types": ["bun-types"],
    "paths": {
      "#mocks": ["./configs/mocks.ts"],
      "@internals/utils": ["./internals/utils/src/index.ts"],
      "@internals/tanstack-query": ["./internals/tanstack-query/src/index.ts"],
      "@kubb/plugin-ts/components": ["./packages/plugin-ts/src/components/index.ts"],
      "@kubb/plugin-ts/presets": ["./packages/plugin-ts/src/presets.ts"],
      "@kubb/plugin-ts/resolvers": ["./packages/plugin-ts/src/resolvers/index.ts"],
      "@kubb/plugin-ts/hooks": ["./packages/plugin-ts/src/hooks/index.ts"],
      "@kubb/plugin-ts": ["./packages/plugin-ts/src/index.ts"],
      "@kubb/plugin-client/components": ["./packages/plugin-client/src/components/index.ts"],
      "@kubb/plugin-client/templates/config.source": ["./packages/plugin-client/src/templates/config.source.ts"],
      "@kubb/plugin-client/templates/clients/axios.source": ["./packages/plugin-client/src/templates/clients/axios.source.ts"],
      "@kubb/plugin-client/templates/clients/fetch.source": ["./packages/plugin-client/src/templates/clients/fetch.source.ts"],
      "@kubb/plugin-client": ["./packages/plugin-client/src/index.ts"],
      "@kubb/plugin-mcp": ["./packages/plugin-mcp/src/index.ts"],
      "@kubb/plugin-msw": ["./packages/plugin-msw/src/index.ts"],
      "@kubb/plugin-react-query": ["./packages/plugin-react-query/src/index.ts"],
      "@kubb/plugin-solid-query": ["./packages/plugin-solid-query/src/index.ts"],
      "@kubb/plugin-svelte-query": ["./packages/plugin-svelte-query/src/index.ts"],
      "@kubb/plugin-vue-query": ["./packages/plugin-vue-query/src/index.ts"],
      "@kubb/plugin-redoc": ["./packages/plugin-redoc/src/index.ts"],
      "@kubb/plugin-faker": ["./packages/plugin-faker/src/index.ts"],
      "@kubb/plugin-cypress": ["./packages/plugin-cypress/src/index.ts"],
      "@kubb/plugin-zod/utils": ["./packages/plugin-zod/src/utils/index.ts"],
      "@kubb/plugin-zod/templates/ToZod.source": ["./packages/plugin-zod/src/templates/ToZod.source.ts"],
      "@kubb/plugin-zod": ["./packages/plugin-zod/src/index.ts"]
    }
  },
  "include": ["./package.json", "./tsdown.config.ts", "./vitest.config.ts", "./src/**/*", "tests"],
  "exclude": ["node_modules", "dist", "tmp", "coverage", "**/__snapshots__/**"]
}
