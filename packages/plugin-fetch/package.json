{
  "name": "@kubb/plugin-fetch",
  "version": "5.0.0-beta.79",
  "description": "Generate a slim, type-safe HTTP client with Kubb based on the native Fetch api.",
  "keywords": [
    "api-client",
    "code-generation",
    "codegen",
    "fetch",
    "http-client",
    "kubb",
    "openapi",
    "swagger",
    "typescript"
  ],
  "license": "MIT",
  "author": "stijnvanhulle",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kubb-labs/plugins.git",
    "directory": "packages/plugin-fetch"
  },
  "files": [
    "src",
    "dist",
    "templates",
    "!/**/**.test.**",
    "!/**/__tests__/**",
    "!/**/__snapshots__/**"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {}
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json",
    "./templates/*": "./templates/*"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "node -e \"require('node:fs').rmSync('./dist', {recursive:true,force:true})\"",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "release": "pnpm publish --no-git-check",
    "release:canary": "bash ../../.github/canary.sh && node ../../scripts/build.js canary && pnpm publish --no-git-check",
    "release:stage": "pnpm stage publish --no-git-check",
    "start": "tsdown --watch",
    "test": "vitest --passWithNoTests",
    "typecheck": "tsc -p ./tsconfig.json --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@kubb/ast": "catalog:",
    "@kubb/core": "catalog:",
    "@kubb/plugin-ts": "workspace:*",
    "@kubb/plugin-zod": "workspace:*",
    "@kubb/renderer-jsx": "catalog:"
  },
  "devDependencies": {
    "@internals/client": "workspace:*",
    "@internals/shared": "workspace:*",
    "@internals/utils": "workspace:*",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@kubb/renderer-jsx": "catalog:"
  },
  "engines": {
    "node": ">=22"
  }
}
