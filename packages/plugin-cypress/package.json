{
  "name": "@kubb/plugin-cypress",
  "version": "5.0.0-alpha.35",
  "description": "Cypress test generator plugin for Kubb, creating end-to-end tests from OpenAPI specifications for automated API testing.",
  "keywords": [
    "api-testing",
    "code-generator",
    "codegen",
    "cypress",
    "e2e-testing",
    "end-to-end",
    "integration-testing",
    "kubb",
    "oas",
    "openapi",
    "plugins",
    "swagger",
    "test-automation",
    "test-generation",
    "testing",
    "typescript"
  ],
  "license": "MIT",
  "author": "stijnvanhulle",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kubb-labs/kubb.git",
    "directory": "packages/plugin-cypress"
  },
  "files": [
    "src",
    "dist",
    "!/**/**.test.**",
    "!/**/__tests__/**",
    "!/**/__snapshots__/**"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {},
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown && size-limit",
    "clean": "npx rimraf ./dist",
    "lint": "bun biome lint .",
    "lint:fix": "bun biome lint --fix --unsafe .",
    "release": "pnpm publish --no-git-check",
    "release:canary": "bash ../../.github/canary.sh && node ../../scripts/build.js canary && pnpm publish --no-git-check",
    "start": "tsdown --watch",
    "test": "vitest --passWithNoTests",
    "typecheck": "tsc -p ./tsconfig.json --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@kubb/core": "catalog:",
    "@kubb/plugin-ts": "workspace:*",
    "@kubb/renderer-jsx": "catalog:"
  },
  "devDependencies": {
    "@internals/utils": "workspace:*"
  },
  "peerDependencies": {
    "@kubb/renderer-jsx": "catalog:"
  },
  "size-limit": [
    {
      "path": "./dist/*.js",
      "limit": "510 KiB",
      "gzip": true
    }
  ],
  "engines": {
    "node": ">=22"
  }
}
